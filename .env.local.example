## You must first activate a Billing Account here: https://platform.openai.com/account/billing/overview
## Then get your OpenAI API Key here: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
# In local dev you can get these by running `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings → API → service_role (secret). Server-only; never use NEXT_PUBLIC_ for this.
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key (server routes only — do not use NEXT_PUBLIC_)
RESEND_API_KEY=

## Follow GitHub Oauth setup steps from Supabase,
## if you choose not to use Github, set first
## value to "false"
NEXT_PUBLIC_AUTH_GITHUB=false
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
